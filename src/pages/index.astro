---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home — Barney Pinkerton">
  <div class="hero">
    <div class="hero-card">
      <div class="hero-left">
        <img src="/assets/images/headshot.jpg" alt="Barney Pinkerton" class="headshot" />
      </div>
      <div class="hero-right">
        <p class="hero-greeting">Hey, I'm Barney!</p>
        <p>I'm a Master's student at NYU studying Music Business &amp; Music Technology. Whenever I have some free time, I like to build and tinker with personalised music tools that make sense of what I listen to and quantify my taste to help with discovering new music I might've missed.</p>
        <p>I also enjoy writing when given the opportunity – especially when I get to blend music with culture, data, and the places I've called home.</p>
        <p>This site is a home for projects, essays, and anything else I feel like sharing – things that exist somewhere between spreadsheets, headphones, and a book. Feel free to get in touch via email or LinkedIn using the links below.</p>
      </div>
    </div>
  </div>
</BaseLayout>


<style>
  .hero {
    min-height: calc(100vh - 66px);
    background-image: url('/assets/images/hometown.jpg');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero-card {
    display: flex;
    gap: 3rem;
    align-items: center;
    width: 90%;
    max-width: 1100px;
    padding: 2.5rem 3rem;
    background: rgba(15, 23, 42, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .hero-left {
    flex: 0 0 220px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .headshot {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .headshot:hover {
    transform: scale(1.04);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.55);
  }

  .hero-right {
    flex: 1;
    color: #f1f5f9;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .hero-right p { margin-bottom: 0.75rem; }
  .hero-right p:last-child { margin-bottom: 0; }

  .hero-greeting {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      overflow-y: auto;
      align-items: flex-start;
      padding: 1.5rem 1rem;
    }
    .hero-card {
      flex-direction: column;
      align-items: center;
      padding: 1.75rem 1.5rem;
      gap: 1.25rem;
      width: 100%;
    }
    .hero-left { flex: 0 0 auto; }
    .headshot { width: 120px; height: 120px; }
    .hero-right { font-size: 0.9rem; text-align: left; }
  }
</style>

